{
  "name": "racetimetracker-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:preview": "tsc && vite build --mode preview",
    "build:prod": "tsc && vite build --mode production",
    "deploy:preview": "npm run build:preview && vercel deploy --prebuilt",
    "deploy:prod": "npm run build:prod && vercel deploy --prod",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@react-oauth/google": "^0.13.4",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "spacetimedb": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-vercel": "^9.1.1"
  }
}