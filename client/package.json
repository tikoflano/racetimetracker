{
  "name": "racetimetracker-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:preview": "tsc && vite build --mode preview",
    "build:prod": "tsc && vite build --mode production",
    "deploy:preview": "bash -c 'npm run build:preview && source ./.env.preview && vercel alias set $(vercel deploy --prebuilt) $PREVIEW_DOMAIN'",
    "deploy:prod": "npm run build:prod && vercel deploy --prod",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mantine/carousel": "^7.17.0",
    "@mantine/core": "^7.17.0",
    "@mantine/dates": "^7.17.0",
    "@mantine/hooks": "^7.17.0",
    "@react-oauth/google": "^0.13.4",
    "@tabler/icons-react": "^3.38.0",
    "@types/leaflet": "^1.9.21",
    "dayjs": "^1.11.0",
    "leaflet": "^1.9.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "spacetimedb": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-vercel": "^9.1.1"
  }
}
